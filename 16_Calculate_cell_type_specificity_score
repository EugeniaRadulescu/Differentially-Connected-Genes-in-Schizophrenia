# --- 1. Function to Calculate Tau Specificity Score ---

# Function remains mathematically correct even for log-transformed data, 
# as it normalizes each row by its maximum value.
calculate_tau_score <- function(expression_vector) {
  # N = number of cell types (columns)
  N <- length(expression_vector)
  
  # Handle the case where N <= 1 
  if (N <= 1) {
    return(NA)
  }
  
  # Find the maximum expression for the gene across all cell types
  # NOTE: This max will be in log2(nTPM+1) space.
  max_expr <- max(expression_vector, na.rm = TRUE)
  
  # If max_expr is zero (i.e., log2(1)=0), the gene is not expressed.
  if (max_expr == 0) {
    return(0) 
  }
  
  # Normalize expression by dividing by the maximum expression (x_hat)
  # x_hat will range from 0 to 1, as required by the formula.
  x_hat <- expression_vector / max_expr
  
  # Apply the Tau formula
  tau <- sum(1 - x_hat, na.rm = TRUE) / (N - 1)
  
  return(tau)
}

