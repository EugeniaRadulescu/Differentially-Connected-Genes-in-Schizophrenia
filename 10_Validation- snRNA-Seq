# Define a function for hdWGCNA processing
run_hdWGCNA_workflow <- function(seurat_obj, wgcna_name_suffix) {
  message("Running hdWGCNA workflow for ", wgcna_name_suffix, "...")
  
  seurat_obj <- SetupForWGCNA(
    seurat_obj,
    gene_select = "fraction",
    fraction = 0.05,
    wgcna_name = wgcna_name_suffix
  )
  collectGarbage()
  
  message("Constructing metacells for ", wgcna_name_suffix, "...")
  seurat_obj <- MetacellsByGroups(
    seurat_obj = seurat_obj,
    group.by = c("orig.ident", "cell_type_idents"),
    reduction = 'pca',
    k = 25,
    min_cells = 100,
    max_shared = 5,
    ident.group = 'cell_type_idents'
  )
  collectGarbage()
  
  message("Normalizing and scaling metacells for ", wgcna_name_suffix, "...")
  seurat_obj <- NormalizeMetacells(seurat_obj)
  seurat_obj <- ScaleMetacells(seurat_obj, features = VariableFeatures(seurat_obj))
  seurat_obj <- RunPCAMetacells(seurat_obj, features = VariableFeatures(seurat_obj))
  seurat_obj <- RunHarmonyMetacells(seurat_obj, group.by.vars = 'orig.ident')
  seurat_obj <- RunUMAPMetacells(seurat_obj, reduction = 'harmony', dims = 1:15)
  
  # Plot metacell UMAPs
  p1 <- DimPlotMetacells(seurat_obj, group.by = 'cell_type_idents') + umap_theme() + ggtitle("Cell Type")
  p2 <- DimPlotMetacells(seurat_obj, group.by = 'orig.ident') + umap_theme() + ggtitle("Sample")
  wrap_plots(p1, p2) %>% print()
  
  save.image(here(base_dir, paste0("Seurat_metacell_obj_normalized_template_", tolower(wgcna_name_suffix), "_", format(Sys.Date(), "%m%d%Y"), ".RData")))
  collectGarbage()
  
  return(seurat_obj)
}

