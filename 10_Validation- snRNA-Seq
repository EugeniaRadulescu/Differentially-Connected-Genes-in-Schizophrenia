# Load packages and the gom.obj

library(GeneOverlap)
library(purrr)
library(openxlsx)

load("~/Enrichment_results.RData")

go_nested_list <- gom_obj_spec@go.nested.list
go_nested_list_org <- gom_obj_spec_organoids@go.nested.list

# --- 2. Extract intersections and prepare for Excel ---

# Initialize an empty list to store data frames for each intersection
all_intersections_dfs <- list()

# Iterate through the first level of the nested list (e.g., "Oligo M1", "Oligo M2")
for (list_name_1 in names(go_nested_list)) {
  # Iterate through the second level (e.g., "C spec", "D spec")
  for (list_name_2 in names(go_nested_list[[list_name_1]])) {
    
    # Construct the full name for the column header
    column_header <- paste(list_name_1, list_name_2, sep = " - ")
    
    # Access the GeneOverlap object
    go_obj <- go_nested_list[[list_name_1]][[list_name_2]]
    
    # Extract the intersection (which is a character vector)
    intersection_genes <- getIntersection(go_obj)
    
    # Convert the intersection to a data frame with a single column
    # If the intersection is empty, this will create a 0-row data frame
    if (length(intersection_genes) > 0) {
      temp_df <- data.frame(Genes = intersection_genes, stringsAsFactors = FALSE)
      colnames(temp_df) <- column_header # Set the column name
      all_intersections_dfs[[column_header]] <- temp_df
    } else {
      # Handle empty intersections by creating an empty data frame with the correct column name
      all_intersections_dfs[[column_header]] <- data.frame(matrix(ncol = 1, nrow = 0), stringsAsFactors = FALSE)
      colnames(all_intersections_dfs[[column_header]]) <- column_header
    }
  }
}

# Combine all data frames into a single data frame.
# We'll use bind_rows, but since the columns might have different numbers of rows,
# we need to pad with NAs. This is usually handled automatically by bind_cols
# if we ensure each data frame only has one column.
# A safer approach for potentially different lengths is to create one large data frame
# where each column is an intersection.

# Find the maximum length of any intersection list
max_len <- max(sapply(all_intersections_dfs, NROW))

# Pad shorter lists with NA to match the maximum length
padded_intersections <- lapply(all_intersections_dfs, function(df) {
  if (NROW(df) < max_len) {
    # Create a vector of NAs to append
    na_vector <- rep(NA, max_len - NROW(df))
    # Combine original column with NAs
    return(data.frame(c(df[[1]], na_vector), stringsAsFactors = FALSE))
  } else {
    return(df)
  }
})

# Rename the single column in each padded data frame to its intended header
padded_intersections <- imap(padded_intersections, ~ {
  names(.x) <- .y
  .x
})


# Combine all padded data frames column-wise
final_table <- do.call(cbind, padded_intersections)


# --- 3. Write to Excel ---

# Define the output file path
output_excel_file <- "Overlaps.xlsx"

# Write the data frame to an Excel file
write.xlsx(final_table, file = output_excel_file, rowNames = FALSE)

cat(paste0("Successfully extracted intersections and saved to '", output_excel_file, "'\n"))


