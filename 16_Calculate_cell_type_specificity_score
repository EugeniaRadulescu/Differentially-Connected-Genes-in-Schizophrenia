names(data2)<-c("kTotal_CTRL","kTotal_SCZ","kIn_CTRL","kIn_SCZ","C_CTRL","C_SCZ","Symbol")

# For Caudate
data3<-as.data.frame(cbind(intraMod_con_refCTRL_modules_01092023$kTotal_CTRL,
                           intraMod_con_refCTRL_modules_01092023$kTotal_SCZ,intraMod_con_refCTRL_modules_01092023$kIn_CTRL,
                           intraMod_con_refCTRL_modules_01092023$kIn_SCZ,intraMod_con_refCTRL_modules_01092023$C_CTRL,
                           intraMod_con_refCTRL_modules_01092023$C_SCZ)) # Caudate

data3$Symbol<-as.character(intraMod_con_refCTRL_modules_01092023$Symbol)

names(data3)<-c("kTotal_CTRL","kTotal_SCZ","kIn_CTRL","kIn_SCZ","C_CTRL","C_SCZ","Symbol")



# --- PART 1: Alignment and Delta/Abs Delta Calculations (Caudate) ---
print("--- Starting Full Caudate Correlation Consolidation ---")

# Alignment (Crucial step for all subsequent calculations)
# Ensure S' matrices are for Caudate

common_genes <- intersect(rownames(results_matrix_S_prime_CTRL), data2$Symbol)
results_matrix_S_prime_CTRL_ALIGNED <- results_matrix_S_prime_CTRL[common_genes, ]
results_matrix_S_prime_SCZ_ALIGNED <- results_matrix_S_prime_SCZ[common_genes, ]
data2_ALIGNED <- data2[match(common_genes, data2$Symbol), ]

# Delta (Signed) Calculation
Delta_kTotal <- data2_ALIGNED$kTotal_SCZ - data2_ALIGNED$kTotal_CTRL
Delta_kIn    <- data2_ALIGNED$kIn_SCZ - data2_ALIGNED$kIn_CTRL
Delta_C      <- data2_ALIGNED$C_SCZ - data2_ALIGNED$C_CTRL
results_matrix_Delta_S_prime <- results_matrix_S_prime_SCZ_ALIGNED - results_matrix_S_prime_CTRL_ALIGNED

# Absolute Delta Calculation
AbsDelta_kTotal <- abs(Delta_kTotal)
AbsDelta_kIn    <- abs(Delta_kIn)
AbsDelta_C      <- abs(Delta_C)
results_matrix_AbsDelta_S_prime <- abs(results_matrix_Delta_S_prime)

# Create temporary Delta Data Frames for the analyze_correlation function
temp_delta_df_hippo <- data.frame(
  Symbol = common_genes,
  kTotal_CTRL = data2_ALIGNED$kTotal_CTRL, # Include original metrics for scenarios 1 & 2
  kTotal_SCZ = data2_ALIGNED$kTotal_SCZ,
  kIn_CTRL = data2_ALIGNED$kIn_CTRL,
  kIn_SCZ = data2_ALIGNED$kIn_SCZ,
  C_CTRL = data2_ALIGNED$C_CTRL,
  C_SCZ = data2_ALIGNED$C_SCZ,
  Delta_kTotal = Delta_kTotal,
  Delta_kIn = Delta_kIn,
  Delta_C = Delta_C,
  AbsDelta_kTotal = AbsDelta_kTotal,
  AbsDelta_kIn = AbsDelta_kIn,
  AbsDelta_C = AbsDelta_C
)


# --- PART 2: Execute all 4 Scenarios and Store Results ---
# Use the function analyze_correlation (defined previously)
final_correlation_list_HIPPO_ALL <- list()

# SCENARIO 1 & 2: CTRL and SCZ Correlations
print("Running Scenario 1 & 2 (CTRL & SCZ)...")
# Note: Using temp_delta_df_caudate as the data frame to keep the structure consistent
for (metric in c("kTotal_CTRL", "kIn_CTRL", "C_CTRL")) {
  final_correlation_list_HIPPO_ALL[[length(final_correlation_list_HIPPO_ALL) + 1]] <- 
    analyze_correlation(metric, results_matrix_S_prime_CTRL_ALIGNED, "CTRL", temp_delta_df_hippo)
}

for (metric in c("kTotal_SCZ", "kIn_SCZ", "C_SCZ")) {
  final_correlation_list_HIPPO_ALL[[length(final_correlation_list_HIPPO_ALL) + 1]] <- 
    analyze_correlation(metric, results_matrix_S_prime_SCZ_ALIGNED, "SCZ", temp_delta_df_hippo)
}

# SCENARIO 3: Signed Delta Correlations
print("Running Scenario 3 (SIGNED_DELTA)...")
for (metric in c("Delta_kTotal", "Delta_kIn", "Delta_C")) {
  final_correlation_list_HIPPO_ALL[[length(final_correlation_list_HIPPO_ALL) + 1]] <- 
    analyze_correlation(metric, results_matrix_Delta_S_prime, "SIGNED_DELTA", temp_delta_df_hippo)
}

# SCENARIO 4: Absolute Delta Correlations
print("Running Scenario 4 (ABS_DELTA)...")
for (metric in c("AbsDelta_kTotal", "AbsDelta_kIn", "AbsDelta_C")) {
  final_correlation_list_HIPPO_ALL[[length(final_correlation_list_HIPPO_ALL) + 1]] <- 
    analyze_correlation(metric, results_matrix_AbsDelta_S_prime, "ABS_DELTA", temp_delta_df_hippo)
}


# --- PART 3: Final Consolidation and Adjustment ---
hippo_full_results <- do.call(rbind, final_correlation_list_HIPPO_ALL)

# Clean up Metric name for printing (e.g., kTotal_CTRL -> kTotal)
hippo_full_results$Metric <- gsub("_(CTRL|SCZ)", "", hippo_full_results$Metric)

# Apply Bonferroni correction across all tests (12 metrics * 9 cell types = 108 tests)
hippo_full_results$Bonf_P_Value <- p.adjust(hippo_full_results$P_Value, method = "bonferroni")


# --- PART 4: Print Final Result ---
print("--- HIPPO FINAL CORRELATION ANALYSIS (CTRL, SCZ, SIGNED_DELTA, ABS_DELTA) ---")
print(hippo_full_results)
collectGarbage()

