# --- PART 2: Alignment and Correlation Function ---

analyze_correlation <- function(topology_vector_name, S_prime_matrix, condition_name, data2_df) {
  
  # Alignment: Ensure genes are common and ordered correctly
  common_genes <- intersect(rownames(S_prime_matrix), data2_df$Symbol)
  
  S_prime_ALIGNED <- S_prime_matrix[common_genes, ]
  data2_ALIGNED <- data2_df[match(common_genes, data2_df$Symbol), ]
  
  # Extract the topology vector
  topology_vector <- data2_ALIGNED[[topology_vector_name]]
  
  # Initialize results
  metric_results_df <- data.frame(
    Scenario = condition_name,
    Metric = topology_vector_name,
    Cell_Type = colnames(S_prime_ALIGNED),
    Spearman_Rho = NA,
    P_Value = NA
  )
  
  # Correlation loop
  for (k_index in 1:ncol(S_prime_ALIGNED)) {
    test_result <- cor.test(topology_vector, 
                            S_prime_ALIGNED[, k_index], 
                            method = "spearman")
    metric_results_df[k_index, "Spearman_Rho"] <- test_result$estimate
    metric_results_df[k_index, "P_Value"] <- test_result$p.value
  }
  return(metric_results_df)
}

