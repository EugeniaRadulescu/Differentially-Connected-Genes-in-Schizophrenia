library(dplyr)
library(broom)

# Get the list of cell types to test
cell_type_cols <- colnames(SignatureMatrix_DLPFC)

# Perform a t-test for each cell type
caudate_Statistical_Test <- caudate_Prop_Data %>%
  # Select only the relevant columns: proportions and the diagnosis (Dx)
  select(Dx, all_of(cell_type_cols)) %>%
  # Pivot to long format for easy iteration and testing
  tidyr::pivot_longer(
    cols = all_of(cell_type_cols),
    names_to = "CellType",
    values_to = "Proportion"
  ) %>%
  # Group by cell type and nest the data
  group_by(CellType) %>%
  tidyr::nest() %>%
  # Run the t-test on the nested data
  mutate(
    test_result = purrr::map(data, ~ t.test(Proportion ~ Dx, data = .x)),
    # Extract model statistics using the broom package
    stats = purrr::map(test_result, tidy)
  ) %>%
  # Unnest the statistics and clean up
  tidyr::unnest(stats) %>%
  select(CellType, estimate1, estimate2, p.value) %>%
  # Rename columns for clarity (estimate1/2 correspond to SCZD/Control mean proportions)
  rename(Mean_Control = estimate1, Mean_SCZD = estimate2, P_Value = p.value)

# Merge with the Delta P table for the final report
caudate_Final_Report <- caudate_Prop_Summary %>%
  left_join(caudate_Statistical_Test, by = "CellType") %>%
  # Select and reorder final columns
  select(CellType, Control, SCZD, Delta_P, P_Value) %>%
  # Apply FDR (False Discovery Rate) correction (Benjamini-Hochberg)
  mutate(FDR = p.adjust(P_Value, method = "BH")) %>%
  arrange(FDR, P_Value)

# Round the final output for presentation
caudate_Final_Report$P_Value <- round(caudate_Final_Report$P_Value, 5)
caudate_Final_Report$FDR <- round(caudate_Final_Report$FDR, 5)

print("--- FINAL caudate REPORT (Delta P & Significance) ---")
print(caudate_Final_Report)

library(dplyr)
library(tidyr)

# Identify rows where Delta_P is 0 (which corresponds to all NaN rows)
caudate_Final_Report_Clean <- caudate_Final_Report %>%
  mutate(
    P_Value = if_else(Delta_P == 0, 1.0, P_Value),
    FDR = if_else(Delta_P == 0, 1.0, FDR)
  ) %>%
  # Re-round the FDR/P-Value after the correction
  mutate(
    P_Value = round(P_Value, 5),
    FDR = round(FDR, 5)
  )

print("--- FINAL caudate REPORT (NaNs Corrected) ---")
print(caudate_Final_Report_Clean)

