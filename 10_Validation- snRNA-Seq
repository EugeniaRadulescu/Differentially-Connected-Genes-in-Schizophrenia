# Define a function to prepare multiMEs data and run LMMs
run_lmm_analysis <- function(seurat_obj, demographics_data_path) {
  multiMEs <- GetMEs(seurat_obj, harmonized = TRUE) %>%
    as.data.frame() %>%
    tibble::rownames_to_column(var = "Sample_Full") # Using tibble::rownames_to_column for clarity
  
  # Clean Sample names
  multiMEs$Sample <- multiMEs$Sample_Full %>%
    stringr::str_remove("_sub.*") # Using stringr::str_remove for clarity
  
  # Determine Dx group (assuming 'CON' for Control, 'SZ' for SCZ)
  multiMEs$Dx_gr <- ifelse(grepl("^CON", multiMEs$Sample_Full), "CTRL", "SZ") %>% as.factor()
  
  # Prepare demographics data
  demographics_data <- readxl::read_excel("Demographics_technical_all_data.xlsx") %>%
    dplyr::select(Individual_ID, Age, PMI, Dx) %>% # Explicitly use dplyr::select()
    dplyr::rename(Sample = Individual_ID)
  
  # Join multiMEs with demographics
  multiMEs_joined <- multiMEs %>%
    dplyr::left_join(demographics_data, by = "Sample")
  
  # Remove rows with NA in demographics (if any)
  multiMEs_joined <- multiMEs_joined %>% tidyr::drop_na(Age, PMI) # Explicitly use tidyr::drop_na
   
  me_cols <- colnames(multiMEs)[grepl("^ME", colnames(multiMEs))]
  
  # Run LMM for each ME module
  lmm_results <- purrr::map_dfr(me_cols, function(me_col) {
    formula_str <- paste0(me_col, " ~ Dx_gr + Age + PMI + (1 | Sample)")
    model <- lmer(as.formula(formula_str), data = multiMEs)
    summary_model <- summary(model)$coefficients %>% as.data.frame()
    
    # Extract relevant row for Dx_gr (assuming 'SZ' is the contrast to 'CTRL')
    dx_row <- summary_model[grep("Dx_grSZ", rownames(summary_model)), ]
    if(nrow(dx_row) == 1) {
      tibble::tibble( # Explicitly use tibble::tibble
        Module = me_col,
        Estimate = dx_row$Estimate,
        Std_Error = dx_row$`Std. Error`,
        t_value = dx_row$`t value`,
        P_value = dx_row$`Pr(>|t|)`
      )
    } else {
      tibble::tibble(Module = me_col, Estimate = NA, Std_Error = NA, t_value = NA, P_value = NA) # Explicitly use tibble::tibble
    }
  })
  return(list(multiMEs_data = multiMEs, lmm_summary = lmm_results))  # return(list(multiMEs_data = multiMEs_joined, lmm_summary = lmm_results))
}


