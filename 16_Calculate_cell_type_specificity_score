# --- PART 1: Define Core Functions and Calculate S' Scores ---

# Define the S' calculation function
calculate_gene_specificity <- function(gene_i, Mk_set, A_original) {
  if (length(Mk_set) == 0) return(NA)
  adjacencies <- A_original[gene_i, Mk_set] 
  return(mean(adjacencies, na.rm = TRUE))
}

calculate_S_prime_matrix <- function(A_matrix, Mk_list) {
  all_genes <- rownames(A_matrix)
  S_prime_matrix <- matrix(NA, 
                           nrow = length(all_genes), 
                           ncol = length(Mk_list),
                           dimnames = list(all_genes, names(Mk_list)))
  
  for (k in names(Mk_list)) {
    Mk_set <- Mk_list[[k]]
    if (length(Mk_set) > 0) {
      S_prime_matrix[, k] <- sapply(all_genes, calculate_gene_specificity, 
                                    Mk_set = Mk_set, A_original = A_matrix)
    }
  }
  return(S_prime_matrix)
}

