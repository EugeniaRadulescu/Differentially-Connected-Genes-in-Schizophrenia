# Utility function for stripping names (can be generalized or simplified)

stripname <- function(x, name) {
  if (!is.list(x)) return(x)
  if (length(nameIndex <- which(names(x) == name))) {
    x <- x[-nameIndex]
  }
  lapply(x, stripname, name)
}

# Function to prepare module gene lists for clusterProfiler
prepare_modules_for_enrichment <- function(modules_df, prefix) {
  modules_list <- split(modules_df, by = "color")
  
  # Remove the 'color' column from sub-dataframes
  modules_list <- lapply(modules_list, function(df) df %>% select(-color))
  
  # Convert to list of gene names
  modules_list_genes <- lapply(modules_list, function(df) as.vector(df$gene_name))
  
  # Rename list elements
  names(modules_list_genes) <- paste0(prefix, " M", seq_along(modules_list_genes), " ", names(modules_list_genes))
  
  return(modules_list_genes)
}

