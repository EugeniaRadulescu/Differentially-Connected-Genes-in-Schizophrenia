# New/Revised 'parse_nTPM' function for better NA handling
parse_nTPM <- function(nTPM_string) {
  if (is.na(nTPM_string) || nTPM_string == "" || !is.character(nTPM_string)) {
    return(NULL)
  }
  parts <- strsplit(nTPM_string, ";")[[1]]
  scores <- setNames(as.numeric(gsub(".*: ", "", parts)),
                     gsub(":.*", "", parts))
  return(scores)
}

