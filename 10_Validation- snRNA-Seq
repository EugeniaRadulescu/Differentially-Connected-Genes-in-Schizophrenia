# Define a function to construct and analyze WGCNA network
analyze_wgcna_network <- function(seurat_obj, cell_type_group_name, wgcna_name_suffix) {
  message("Analyzing WGCNA network for ", cell_type_group_name, " (", wgcna_name_suffix, ")...")
  
  # Set expression data for WGCNA
  seurat_obj <- SetDatExpr(
    seurat_obj,
    group_name = cell_type_group_name, # Example: "Vip"
    group.by = 'cell_type_idents',
    assay = 'RNA',
    slot = 'data'
  )
  collectGarbage()
  
  # Test soft powers
  seurat_obj <- TestSoftPowers(seurat_obj, networkType = 'signed')
  plot_list <- PlotSoftPowers(seurat_obj)
  wrap_plots(plot_list, ncol = 2) %>% print()
  power_table <- GetPowerTable(seurat_obj)
  message("Soft power table for ", cell_type_group_name, ":")
  print(head(power_table))
  
  # Construct co-expression network
  message("Constructing network for ", cell_type_group_name, "...")
  seurat_obj <- ConstructNetwork(seurat_obj, tom_name = 'TOM')
  collectGarbage()
  
  # Plot dendrogram
  PlotDendrogram(seurat_obj, main = paste0('Module Dendrogram (', cell_type_group_name, ')')) %>% print()
  
  # Calculate module eigengenes (harmonized MEs)
  message("Calculating module eigengenes for ", cell_type_group_name, "...")
  seurat_obj <- ModuleEigengenes(seurat_obj, group.by.vars = "orig.ident")
  save.image(here(base_dir, paste0("Ruzicka_seurat_metacell_obj_", cell_type_group_name, "_normalized_", format(Sys.Date(), "%m%d%Y"), ".RData")))
  collectGarbage()
  
  # Compute eigengene-based connectivity (kME)
  message("Computing kME for ", cell_type_group_name, "...")
  seurat_obj <- ModuleConnectivity(seurat_obj, group.by = 'cell_type_idents', group_name = cell_type_group_name) # Adjust group_name as needed
  
  # Get and rename modules
  seurat_obj <- ResetModuleNames(seurat_obj, new_name = paste0(cell_type_group_name, "-M"))
  
  # Plot KMEs
  PlotKMEs(seurat_obj, ncol = 5) %>% print()
  
  # Get module assignment table and hub genes
  modules <- GetModules(seurat_obj) %>% subset(module != 'grey')
  hub_df <- GetHubGenes(seurat_obj, n_hubs = 20)
  message("Hub genes for ", cell_type_group_name, ":")
  print(hub_df)
  
  return(list(seurat_obj = seurat_obj, modules = modules, hub_df = hub_df))
}

