# Define a function to process individual Seurat objects
process_seurat_sample <- function(file_path) {
  # Extract sample name from file path
  sample_name <- tools::file_path_sans_ext(basename(file_path)) %>%
    str_remove("-annotated_matrix")
  
  message("Processing sample: ", sample_name)
  
  # Read data
  data_matrix <- read.delim(file_path, stringsAsFactors = TRUE) %>%
    column_to_rownames(var = "featurekey")
  
  # Create Seurat object
  seurat_obj <- CreateSeuratObject(
    counts = data_matrix,
    project = sample_name,
    min.cells = 3,
    min.features = 200
  )
  
  # Calculate mitochondrial percentage
  seurat_obj[["percent.mt"]] <- PercentageFeatureSet(seurat_obj, pattern = "^MT-")
  
  return(seurat_obj)
}

